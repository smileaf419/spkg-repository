HOMEPAGE="https://www.x.org/wiki/"
DESCRIPTION="VMWare SVGA Guest video driver"
LICENSE="XFree86"
SRC_URI=("https://www.x.org/pub/individual/driver/$PKG_NAME-${PKG_VER}.tar.xz")
PATCHES=()
DEPS=""
BDEPS=""
RDEPS=""
ARCHS="x86 x86_64"
SLOT=0

src_configure() {
	./configure --prefix=/usr \
				--sysconfdir=/etc \
				--localstatedir=/var \
				--disable-static
}

src_test() { :; }
